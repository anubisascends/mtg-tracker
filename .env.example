# Copy this file to .env and fill in your values before running with Docker.

# JWT signing secret — must be at least 32 characters, use a random string in production
JWT_SECRET=change-me-to-a-random-32-char-string

# Admin account created automatically on first startup
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_USERNAME=admin

# Set to "true" to seed sample players, events, and decks on startup
SEED_SAMPLE_DATA=false

# Optional SMTP settings for sending player invite emails
# Leave blank to disable email — admin will see the reset link directly instead
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENABLE_SSL=true
